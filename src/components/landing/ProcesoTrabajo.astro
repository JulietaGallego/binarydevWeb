---
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Button from '@/components/ui/form/Button/Button.astro';

const steps = [
  {
    name: 'Diagnóstico inicial',
    desc: 'Entiendo la prioridad de tu negocio y definimos la solución ideal para vos.',
    icon: 'brand-astro',
  },
  {
    name: 'Diseño y desarrollo',
    desc: 'Construyo tu plataforma enfocándome en la velocidad, la estética y la facilidad de uso.',
    icon: 'brand-tailwind',
  },
  {
    name: 'Lanzamiento y soporte:',
    desc: 'Tu web queda online y lista para recibir clientes, con acompañamiento para que aprendas a usarla.',
    icon: 'brand-typescript',
  },
] as const;
---

<section class="border-y border-border bg-background-secondary py-[var(--space-section-sm)]">
  <div class="mx-auto max-w-6xl px-6">
    <header class="mb-12 flex flex-col items-start justify-between gap-6 md:flex-row md:items-end">
      <div>
        <h2 class="font-display text-3xl font-bold text-foreground md:text-4xl">
          Todo lo que necesitás. 
          <br />
          <span class="text-brand-500">Sin costos de más.</span>
        </h2>
        <p class="mt-4 max-w-2xl text-lg text-foreground-muted">
          Un proceso claro, sin tecnicismos ni vueltas.
        </p>
      </div>
      
      <Button size="lg" href="https://docs.deployvelocity.com" target="_blank">
        ¿Qué web necesitás?
      </Button>
    </header>

    <ol class="grid grid-cols-1 gap-[var(--space-content-gap)] md:grid-cols-3">
      {steps.map((item, i) => (
        <li 
          class="animate-slide-up" 
          style={`animation-delay: ${i * 100}ms; animation-fill-mode: backwards;`}
        >
          <Card variant="elevated" padding="md" hover={true} class="h-full">
            <div class="flex flex-col items-center gap-4 md:items-start text-center md:text-left">
              <div class="flex w-full items-start justify-between">
                <div class="flex items-center justify-center rounded-lg bg-background p-2 ring-1 ring-border">
                  <Icon name={item.icon} size="lg" />
                </div>
                <span class="font-display text-4xl font-black opacity-10 select-none">{i + 1}</span>
              </div>
              <h3 class="font-display text-lg font-bold text-foreground">{item.name}</h3>
              <p class="text-sm leading-relaxed text-foreground-muted">{item.desc}</p>
            </div>
          </Card>
        </li>
      ))}
    </ol>
  </div>
</section>