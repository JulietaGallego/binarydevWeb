---
import PageLayout from '@/layouts/PageLayout.astro';
import BlogCard from '@/components/blog/BlogCard.astro';
import CTA from '@/components/landing/CTA.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => {
  return import.meta.env.PROD ? data.draft !== true : true;
});

const posts = allPosts
  .filter((post) => post.data.locale === 'en')
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());

const featuredPosts = posts.filter((post) => post.data.featured);
const nonFeaturedPosts = posts.filter((post) => !post.data.featured);
const regularPosts = nonFeaturedPosts.length > 0 ? nonFeaturedPosts : posts;

const getPostUrl = (postId: string) => `/blog/${postId.replace('en/', '')}`;

const topics = ['Diseño web', 'Estrategia digital', 'E-commerce', 'UX & Accesibilidad', 'SEO'];
---

<PageLayout
  title="Blog — BinaryDev"
  description="Consejos de diseño web, estrategia digital y e-commerce para hacer crecer tu negocio en internet."
>

  <!-- ── Hero del blog ─────────────────────────────────────────── -->
  <section class="blog-hero relative overflow-hidden border-b border-border bg-background-secondary py-20 lg:py-28">

    <!-- Glow sutil de fondo -->
    <div class="pointer-events-none absolute -top-32 right-0 h-96 w-96 rounded-full bg-brand-500/8 blur-[100px]" aria-hidden="true"></div>

    <div class="relative mx-auto max-w-4xl px-6 text-center">

      <!-- Label -->
      <p class="mb-5 text-sm font-bold uppercase tracking-[0.2em] text-brand-500">Blog</p>

      <!-- Título -->
      <h1 class="font-display mb-5 text-4xl font-black leading-[1.08] tracking-tight text-foreground text-balance sm:text-5xl lg:text-6xl">
        Ideas para hacer crecer
        <span class="text-brand-500"> tu negocio digital.</span>
      </h1>

      <!-- Descripción -->
      <p class="mx-auto mb-10 max-w-xl text-lg leading-relaxed text-foreground-muted">
        Consejos prácticos de diseño web, estrategia digital y e-commerce — sin tecnicismos, directo al punto.
      </p>

      <!-- Topic pills -->
      <div class="flex flex-wrap items-center justify-center gap-2">
        {topics.map((t) => (
          <span class="rounded-full border border-border bg-background px-4 py-1.5 text-sm font-medium text-foreground-muted transition-colors hover:border-brand-500/50 hover:text-brand-500">
            {t}
          </span>
        ))}
      </div>

    </div>
  </section>

  <!-- ── Posts destacados ───────────────────────────────────────── -->
  {featuredPosts.length > 0 && (
    <section class="py-16 lg:py-20">
      <div class="mx-auto max-w-6xl px-6">
        <h2 class="font-display mb-8 flex items-center gap-2 text-xl font-bold text-foreground">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" class="text-brand-500" aria-hidden="true">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
          </svg>
          Destacados
        </h2>
        <div class="grid gap-6 md:grid-cols-2">
          {featuredPosts.map((post) => (
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              href={getPostUrl(post.id)}
              publishedAt={post.data.publishedAt}
              tags={post.data.tags}
              author={post.data.author}
              image={post.data.image}
              featured={true}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ── Todos los posts ────────────────────────────────────────── -->
  <section class:list={["pb-20 lg:pb-28", featuredPosts.length > 0 && nonFeaturedPosts.length > 0 ? "bg-background-secondary pt-16" : "pt-0"]}>
    <div class="mx-auto max-w-6xl px-6">

      {featuredPosts.length > 0 && nonFeaturedPosts.length > 0 && (
        <h2 class="font-display mb-8 text-xl font-bold text-foreground">Todos los artículos</h2>
      )}

      {regularPosts.length > 0 ? (
        <div class="blog-masonry">
          {regularPosts.map((post) => (
            <div class="blog-masonry-item">
              <BlogCard
                title={post.data.title}
                description={post.data.description}
                href={getPostUrl(post.id)}
                publishedAt={post.data.publishedAt}
                tags={post.data.tags}
                author={post.data.author}
                image={post.data.image}
              />
            </div>
          ))}
        </div>
      ) : (
        <div class="py-24 text-center">
          <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-2xl border border-border bg-background-secondary">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-foreground-subtle" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          </div>
          <p class="text-lg font-semibold text-foreground">Próximamente</p>
          <p class="mt-1 text-foreground-muted">Los primeros artículos están en camino.</p>
        </div>
      )}

    </div>
  </section>

  <CTA />

</PageLayout>

<style>
  .blog-masonry {
    columns: 1;
    column-gap: 2rem;
  }
  @media (min-width: 640px) {
    .blog-masonry { columns: 2; }
  }
  @media (min-width: 1024px) {
    .blog-masonry { columns: 3; }
  }

  .blog-masonry-item {
    break-inside: avoid;
    margin-bottom: 2.5rem;
  }
</style>
