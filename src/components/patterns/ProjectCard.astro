---
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Button from '@/components/ui/form/Button/Button.astro';

interface Props {
  title: string;
  description: string;
  image?: string;
  url?: string;
  tags?: string[];
  index?: number;
}

const { title, description, image, url, tags = [], index = 0 } = Astro.props;
const reversed = index % 2 !== 0;
const urlDisplay = url ? new URL(url).hostname.replace(/^www\./, '') : '';
---

<article class:list={[
  "group grid grid-cols-1 gap-4",
  reversed ? "md:grid-cols-[40%_60%]" : "md:grid-cols-[60%_40%]",
  reversed && "md:[&>*:first-child]:order-2 md:[&>*:last-child]:order-1"
]}>

  <!-- Imagen -->
  <div
    class="tilt-card rounded-2xl overflow-hidden border border-border bg-secondary"
    style="max-height: 50vh; min-height: 220px; transform-style: preserve-3d; will-change: transform;"
  >
    {image ? (
      <img
        src={image}
        alt={`Mockup de ${title}`}
        class="w-full h-full object-cover"
        style="max-height: 50vh;"
        loading="lazy"
        draggable="false"
      />
    ) : (
      <div class="w-full h-full min-h-[220px] flex items-center justify-center bg-gradient-to-br from-brand-500/10 to-brand-500/5">
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24"
          fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"
          stroke-linejoin="round" class="text-brand-500/30" aria-hidden="true">
          <rect width="20" height="14" x="2" y="3" rx="2"/>
          <path d="M8 21h8M12 17v4"/>
        </svg>
      </div>
    )}
  </div>

  <!-- Texto -->
  <div class="flex flex-col justify-start gap-4 rounded-2xl border border-border bg-card p-8 md:p-10">

    <h3 class="text-xl font-bold text-foreground leading-snug">{title}</h3>

    {tags.length > 0 && (
      <div class="flex flex-wrap gap-1.5">
        {tags.map((tag) => (
          <Badge variant="default" size="sm">{tag}</Badge>
        ))}
      </div>
    )}

    <p class="text-foreground-muted leading-relaxed">{description}</p>

    {url && (
      <div>
        <a
          href={url}
          target="_blank"
          rel="noopener noreferrer"
          class="roll-btn inline-flex items-center gap-2 px-4 py-2 rounded-lg border border-border bg-card text-sm font-medium text-foreground hover:border-brand-500 hover:text-brand-500 transition-colors duration-300"
        >
          <span class="roll-btn-text" aria-label={`Ir a la web: ${url}`}>
            <span data-text={urlDisplay}>Ir a la web</span>
          </span>
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
            fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
            stroke-linejoin="round" aria-hidden="true">
            <path d="M15 3h6v6M10 14 21 3M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
          </svg>
        </a>
      </div>
    )}

  </div>
</article>

<style>
  .roll-btn-text {
    position: relative;
    display: inline-block;
    overflow: hidden;
    height: 1.5em;
    vertical-align: middle;
  }

  .roll-btn-text span {
    display: block;
    line-height: 1.5em;
    transition: transform 0.5s cubic-bezier(0.76, 0, 0.24, 1);
    white-space: nowrap;
  }

  .roll-btn-text span::after {
    content: attr(data-text);
    position: absolute;
    left: 0;
    top: 100%;
    line-height: 1.5em;
    white-space: nowrap;
  }

  .roll-btn:hover .roll-btn-text span {
    transform: translateY(-100%);
  }
</style>

<script>
  function initTilt() {
    if (!window.matchMedia('(hover: hover) and (pointer: fine)').matches) return;
    document.querySelectorAll<HTMLElement>('.tilt-card').forEach((card) => {
      if (card.dataset.tiltInit) return;
      card.dataset.tiltInit = 'true';
      const STRENGTH = 7;
      card.addEventListener('mousemove', (e) => {
        const rect = card.getBoundingClientRect();
        const x = (e.clientX - rect.left) / rect.width  - 0.5;
        const y = (e.clientY - rect.top)  / rect.height - 0.5;
        card.style.transition = 'transform 0.08s ease-out';
        card.style.transform = `perspective(600px) rotateY(${x * STRENGTH}deg) rotateX(${-y * STRENGTH}deg) scale3d(1.02,1.02,1.02)`;
      });
      card.addEventListener('mouseleave', () => {
        card.style.transition = 'transform 0.4s ease-out';
        card.style.transform = 'perspective(600px) rotateY(0deg) rotateX(0deg) scale3d(1,1,1)';
      });
    });
  }

  initTilt();
  document.addEventListener('astro:page-load', initTilt);
</script>
