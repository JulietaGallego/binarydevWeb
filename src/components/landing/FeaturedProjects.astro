---
import { getCollection } from 'astro:content';
import ProjectCard from '@/components/patterns/ProjectCard.astro';
import Button from '@/components/ui/form/Button/Button.astro';

const featured = (await getCollection('projects', ({ data }) =>
  !data.draft && data.featured
)).sort((a, b) => a.data.order - b.data.order);
---

{featured.length > 0 && (
  <section id="featured-projects" class="relative z-10 bg-background pt-32 pb-20">
    <div class="container">

      <div id="fp-header" class="mb-10 flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4">
        <div>
          <p class="text-xs font-bold uppercase tracking-widest text-brand-500 mb-2">Portfolio</p>
          <h2 id="fp-title" class="font-black text-foreground leading-tight" style="font-size: clamp(2rem, 10vw, 7rem); will-change: font-size;">
            Proyectos<br/>destacados
          </h2>
        </div>
        <div id="fp-cta" style="opacity: 0; transform: translateY(12px);">
          <Button href="/proyectos" variant="outline" size="sm">
            Ver todos
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
              fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"
              stroke-linejoin="round" aria-hidden="true" class="ml-1">
              <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
            </svg>
          </Button>
        </div>
      </div>

      <div id="fp-list" class="flex flex-col gap-6" style="opacity: 0; transform: translateY(32px);">
        {featured.map((project, i) => (
          <ProjectCard
            title={project.data.title}
            description={project.data.description}
            image={project.data.image}
            url={project.data.url}
            tags={project.data.tags}
            index={i}
          />
        ))}
      </div>

    </div>
  </section>
)}

<script>
  function initFeaturedAnimation() {
    const section = document.getElementById('featured-projects');
    const title   = document.getElementById('fp-title') as HTMLElement | null;
    const list    = document.getElementById('fp-list')  as HTMLElement | null;
    const cta     = document.getElementById('fp-cta')   as HTMLElement | null;
    if (!section || !title || !list || !cta) return;

    const FONT_START = 7;   // rem — tamaño grande al entrar
    const FONT_END   = 2;   // rem — tamaño final (normal)

    function update() {
      const rect     = section.getBoundingClientRect();
      const vh       = window.innerHeight;

      // progress: 0 cuando el top de la sección toca el fondo del viewport
      //           1 cuando el top de la sección llega al top del viewport
      const raw      = 1 - rect.top / vh;
      const progress = Math.min(1, Math.max(0, raw));

      // Título: interpola de FONT_START a FONT_END
      const fontSize = FONT_START + (FONT_END - FONT_START) * progress;
      title.style.fontSize = `clamp(${FONT_END}rem, ${fontSize * 2}vw, ${fontSize}rem)`;

      // Lista y CTA: aparecen en la segunda mitad del progress
      const listProgress = Math.min(1, Math.max(0, (progress - 0.5) * 2));
      list.style.opacity  = String(listProgress);
      list.style.transform = `translateY(${(1 - listProgress) * 32}px)`;
      cta.style.opacity   = String(listProgress);
      cta.style.transform = `translateY(${(1 - listProgress) * 12}px)`;
    }

    window.addEventListener('scroll', update, { passive: true });
    update();
  }

  initFeaturedAnimation();
  document.addEventListener('astro:page-load', initFeaturedAnimation);
</script>
