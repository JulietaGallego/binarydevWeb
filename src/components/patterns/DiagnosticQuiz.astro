---
// src/components/landing/DiagnosticQuiz.astro
// Componente de quiz diagnóstico. Toda la data está en src/data/quiz.ts.
import { getStep, getResult, TOTAL_STEPS } from "../../lib/quiz";

// Pre-renderizamos el primer paso en el servidor para evitar flash en carga
const firstStep = getStep(1);
---

<div
  id="quiz-container"
  class="w-full max-w-3xl mx-auto bg-card rounded-2xl shadow-xl overflow-hidden border border-border flex flex-col"
  style="min-height: 560px;"
>
  <!-- Barra de progreso -->
  <div class="w-full bg-secondary h-1.5">
    <div
      id="progress-bar"
      class="bg-brand-500 h-full"
      style="width: 0%; transition: width 0.5s ease;"
    ></div>
  </div>

  <!-- Header -->
  <div class="px-6 pt-5 pb-4 flex items-center justify-between border-b border-border/50">
    <button
      id="prev-btn"
      type="button"
      class="group flex items-center gap-1.5 text-sm font-medium text-foreground-muted hover:text-foreground transition-colors"
      style="visibility: hidden;"
      aria-label="Volver al paso anterior"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="transition-transform group-hover:-translate-x-0.5"
        aria-hidden="true"
      >
        <path d="m15 18-6-6 6-6" />
      </svg>
      Volver
    </button>

    <span
      id="step-indicator"
      class="text-xs font-bold uppercase tracking-widest text-foreground-subtle ml-auto"
      aria-live="polite"
    >
      Paso 1 de {TOTAL_STEPS}
    </span>
  </div>

  <!-- Área de contenido -->
  <div class="flex-1 px-6 py-8 md:px-10 md:py-10">
    <div id="step-content">
      <!--
        SSR: primer paso pre-renderizado para evitar CLS.
        El script toma el control apenas hidrata.
      -->
      <div class="mb-7">
        <h2 class="text-xl font-bold text-foreground leading-snug">
          {firstStep.title}
        </h2>
        {firstStep.subtitle && (
          <p class="mt-1.5 text-sm text-foreground-muted">{firstStep.subtitle}</p>
        )}
      </div>

      <div class="flex flex-col gap-3">
        {firstStep.options.map((opt) => (
          <button
            type="button"
            data-option-id={opt.id}
            class="quiz-option group w-full text-left rounded-xl border border-border bg-card p-4 md:p-5 hover:border-brand-500 hover:shadow-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500 active:scale-[0.99] transition-all duration-200"
          >
            <div class="flex items-start gap-3">
              <span
                class="mt-0.5 flex-shrink-0 w-5 h-5 rounded-full border-2 border-border group-hover:border-brand-500 transition-colors"
                aria-hidden="true"
              ></span>
              <div>
                <p class="text-sm font-semibold text-foreground group-hover:text-brand-500 transition-colors leading-snug">
                  {opt.label}
                </p>
                {opt.detail && (
                  <p class="mt-1 text-xs text-foreground-muted leading-relaxed">
                    {opt.detail}
                  </p>
                )}
              </div>
            </div>
          </button>
        ))}
      </div>
    </div>
  </div>
</div>

<script>
  import { getStep, getResult, TOTAL_STEPS }  from "../../lib/quiz";
  
  import type { QuizStep }  from "../../lib/quiz";

  // ─── ESTADO ───────────────────────────────────────────────────────────────

  let currentStep = 1;
  const sel = { s1: "", s2: "", s3: "" };

  // ─── REFERENCIAS DOM ──────────────────────────────────────────────────────

  const contentEl  = document.getElementById("step-content")!;
  const prevBtn    = document.getElementById("prev-btn") as HTMLButtonElement;
  const progressEl = document.getElementById("progress-bar")!;
  const indicator  = document.getElementById("step-indicator")!;

  // ─── HEADER ───────────────────────────────────────────────────────────────

  function updateHeader() {
    const pct =
      currentStep <= TOTAL_STEPS
        ? (currentStep / (TOTAL_STEPS + 1)) * 100
        : 100;
    progressEl.style.width = `${pct}%`;

    indicator.textContent =
      currentStep <= TOTAL_STEPS
        ? `Paso ${currentStep} de ${TOTAL_STEPS}`
        : "Tu resultado";

    prevBtn.style.visibility = currentStep > 1 ? "visible" : "hidden";
  }

  // ─── TRANSICIÓN ───────────────────────────────────────────────────────────

  function transition(renderFn: () => void) {
    contentEl.style.transition = "opacity 0.2s ease, transform 0.2s ease";
    contentEl.style.opacity = "0";
    contentEl.style.transform = "translateX(10px)";

    setTimeout(() => {
      renderFn();
      contentEl.style.transform = "translateX(-10px)";
      contentEl.style.opacity = "0";

      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          contentEl.style.transition = "opacity 0.25s ease, transform 0.25s ease";
          contentEl.style.opacity = "1";
          contentEl.style.transform = "translateX(0)";
        });
      });
    }, 220);
  }

  // ─── RENDER OPCIONES ──────────────────────────────────────────────────────

  function renderOptions(step: QuizStep) {
    contentEl.innerHTML = `
      <div class="mb-7">
        <h2 class="text-xl font-bold text-foreground leading-snug">${step.title}</h2>
        ${step.subtitle
          ? `<p class="mt-1.5 text-sm text-foreground-muted">${step.subtitle}</p>`
          : ""}
      </div>
      <div class="flex flex-col gap-3" id="options-list"></div>
    `;

    const list = document.getElementById("options-list")!;

    step.options.forEach((opt) => {
      const btn = document.createElement("button");
      btn.type = "button";
      btn.setAttribute("data-option-id", opt.id);
      btn.className = [
        "quiz-option group w-full text-left",
        "rounded-xl border border-border bg-card",
        "p-4 md:p-5",
        "hover:border-brand-500 hover:shadow-md",
        "focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500",
        "active:scale-[0.99] transition-all duration-200",
      ].join(" ");

      btn.innerHTML = `
        <div class="flex items-start gap-3">
          <span
            class="mt-0.5 flex-shrink-0 w-5 h-5 rounded-full border-2 border-border
                   group-hover:border-brand-500 transition-colors"
            aria-hidden="true"
          ></span>
          <div>
            <p class="text-sm font-semibold text-foreground group-hover:text-brand-500
                      transition-colors leading-snug">
              ${opt.label}
            </p>
            ${opt.detail
              ? `<p class="mt-1 text-xs text-foreground-muted leading-relaxed">${opt.detail}</p>`
              : ""}
          </div>
        </div>
      `;

      btn.addEventListener("click", () => handleOptionClick(opt.id));
      list.appendChild(btn);
    });
  }

  // ─── RENDER RESULTADO ─────────────────────────────────────────────────────

  function renderResult() {
    const res = getResult(sel.s1, sel.s2, sel.s3);

    contentEl.innerHTML = `
      <div class="space-y-6">

        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full
                    bg-brand-500/10 border border-brand-500/20">
          <span class="w-1.5 h-1.5 rounded-full bg-brand-500" aria-hidden="true"></span>
          <span class="text-xs font-bold text-brand-500 uppercase tracking-widest">
            ${res.service}
          </span>
        </div>

        <div>
          <h2 class="text-2xl font-black text-foreground leading-tight">${res.title}</h2>
          <p class="mt-3 text-foreground-muted leading-relaxed">${res.desc}</p>
        </div>

        <hr class="border-border/50" />

        <div class="space-y-3">
          <p class="text-sm font-semibold text-foreground">
            ¿Querés que trabajemos en esto juntos?
          </p>
          <div class="flex flex-col sm:flex-row gap-3">
            <a
              href="/contacto"
              class="inline-flex items-center justify-center gap-2 px-5 py-2.5 rounded-xl
                     bg-brand-500 text-white text-sm font-semibold
                     hover:bg-brand-600 transition-colors"
            >
              Hablemos del proyecto
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16"
                viewBox="0 0 24 24" fill="none" stroke="currentColor"
                stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"
                aria-hidden="true">
                <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
              </svg>
            </a>
            <button
              id="restart-btn"
              type="button"
              class="inline-flex items-center justify-center gap-2 px-5 py-2.5 rounded-xl
                     border border-border bg-card text-sm font-medium text-foreground-muted
                     hover:text-foreground hover:border-foreground-muted transition-colors"
            >
              Volver a empezar
            </button>
          </div>
        </div>

      </div>
    `;

    document.getElementById("restart-btn")?.addEventListener("click", restart);
  }

  // ─── LÓGICA DE NAVEGACIÓN ─────────────────────────────────────────────────

  function handleOptionClick(optionId: string) {
    if (currentStep === 1) sel.s1 = optionId;
    else if (currentStep === 2) sel.s2 = optionId;
    else if (currentStep === 3) sel.s3 = optionId;

    currentStep++;
    updateHeader();

    transition(() => {
      if (currentStep > TOTAL_STEPS) {
        renderResult();
      } else {
        renderOptions(getStep(currentStep, sel.s1));
      }
    });
  }

  function goBack() {
    if (currentStep <= 1) return;
    currentStep--;
    if (currentStep === 3) sel.s3 = "";
    if (currentStep === 2) sel.s2 = "";
    updateHeader();
    transition(() => renderOptions(getStep(currentStep, sel.s1)));
  }

  function restart() {
    currentStep = 1;
    sel.s1 = sel.s2 = sel.s3 = "";
    updateHeader();
    transition(() => renderOptions(getStep(1)));
  }

  // ─── EVENTOS ──────────────────────────────────────────────────────────────

  prevBtn.addEventListener("click", goBack);

  // Delegación de eventos para el primer paso (pre-renderizado por SSR)
  contentEl.addEventListener("click", (e) => {
    const btn = (e.target as Element).closest<HTMLButtonElement>("[data-option-id]");
    if (btn && currentStep === 1) {
      handleOptionClick(btn.dataset.optionId!);
    }
  });

  // Sincronizar header con el SSR inicial
  updateHeader();
</script>
