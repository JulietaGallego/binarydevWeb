---
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Button from '@/components/ui/form/Button/Button.astro';

interface Props {
  title: string;
  description: string;
  image?: string;
  url?: string;
  tags?: string[];
  index?: number;
}

const { title, description, image, url, tags = [], index = 0 } = Astro.props;
const reversed = index % 2 !== 0;
---

<article class:list={[
  "group grid grid-cols-1 md:grid-cols-2 gap-0 rounded-2xl border border-border bg-card overflow-hidden transition-shadow duration-200 hover:shadow-lg",
  reversed && "md:[&>*:first-child]:order-2 md:[&>*:last-child]:order-1"
]}>

  <!-- Imagen -->
  <div class="aspect-video md:aspect-auto overflow-hidden bg-secondary">
    {image ? (
      <img
        src={image}
        alt={`Mockup de ${title}`}
        class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
        loading="lazy"
      />
    ) : (
      <div class="w-full h-full min-h-[220px] flex items-center justify-center bg-gradient-to-br from-brand-500/10 to-brand-500/5">
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24"
          fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"
          stroke-linejoin="round" class="text-brand-500/30" aria-hidden="true">
          <rect width="20" height="14" x="2" y="3" rx="2"/>
          <path d="M8 21h8M12 17v4"/>
        </svg>
      </div>
    )}
  </div>

  <!-- Texto -->
  <div class="flex flex-col justify-center gap-4 p-8 md:p-10">

    {tags.length > 0 && (
      <div class="flex flex-wrap gap-1.5">
        {tags.map((tag) => (
          <Badge variant="default" size="sm">{tag}</Badge>
        ))}
      </div>
    )}

    <div>
      <h3 class="text-xl font-bold text-foreground leading-snug">{title}</h3>
      <p class="mt-2 text-foreground-muted leading-relaxed">{description}</p>
    </div>

    {url && (
      <div>
        <Button href={url} variant="outline" size="sm" target="_blank" rel="noopener noreferrer">
          Ver proyecto
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
            fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
            stroke-linejoin="round" aria-hidden="true" class="ml-1">
            <path d="M15 3h6v6M10 14 21 3M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
          </svg>
        </Button>
      </div>
    )}

  </div>
</article>
