---
import PageLayout from '@/layouts/PageLayout.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import CTA from '@/components/landing/CTA.astro';

const services = [
  {
    tag: 'PRESENCIA DIGITAL',
    title: 'Sitio web profesional',
    description: 'Tu negocio merece una presencia digital que transmita confianza desde el primer segundo. Diseño y desarrollo sitios web a medida — institucionales, portfolios, landings — con foco en rendimiento, accesibilidad y conversión.',
    items: ['Diseño UI personalizado', 'Mobile-first y accesible', 'SEO técnico incluido', 'Carga ultrarrápida'],
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="14" x="2" y="3" rx="2"/><path d="M8 21h8M12 17v4"/></svg>`,
    color: 'brand',
    href: '/contacto',
  },
  {
    tag: 'VENTAS ONLINE',
    title: 'Tienda e-commerce',
    description: 'Vendé las 24 horas sin depender de WhatsApp ni de coordinaciones manuales. Construyo tiendas online con catálogo real, pagos integrados (Mercado Pago, tarjetas) y gestión de pedidos automática.',
    items: ['Catálogo con stock real', 'Mercado Pago y tarjetas', 'Pedidos automáticos', 'Panel de administración'],
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>`,
    color: 'green',
    href: '/contacto',
  },
  {
    tag: 'MEJORA CONTINUA',
    title: 'Auditoría web',
    description: 'A veces el problema no es no tener web, sino que la que tenés no está funcionando. Analizo tu sitio en profundidad — experiencia de usuario, accesibilidad, contenidos, SEO — y te entrego un plan de acción concreto.',
    items: ['Auditoría UX y navegación', 'Accesibilidad WCAG', 'Revisión de contenidos', 'Informe + recomendaciones'],
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/><path d="M11 8v6M8 11h6"/></svg>`,
    color: 'yellow',
    href: '/contacto',
  },
  {
    tag: 'EFICIENCIA OPERATIVA',
    title: 'Automatización de procesos',
    description: 'El tiempo que perdés en tareas repetitivas es tiempo que no invertís en crecer. Automatizo flujos de trabajo con herramientas a medida — desde macros en Excel/VBA hasta aplicaciones web que reemplazan procesos manuales por completo.',
    items: ['Macros y dashboards Excel', 'Apps web a medida', 'Integración de sistemas', 'Reportes automáticos'],
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 20a8 8 0 1 0 0-16 8 8 0 0 0 0 16z"/><path d="M12 14a2 2 0 1 0 0-4 2 2 0 0 0 0 4z"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>`,
    color: 'purple',
    href: '/contacto',
  },
];

const colorMap: Record<string, { bg: string; icon: string; tag: string; border: string }> = {
  brand:  { bg: 'bg-brand-500/10',   icon: 'text-brand-500',   tag: 'text-brand-500',   border: 'border-brand-500/20' },
  green:  { bg: 'bg-green-500/10',   icon: 'text-green-500',   tag: 'text-green-500',   border: 'border-green-500/20' },
  yellow: { bg: 'bg-accent-yellow/15', icon: 'text-amber-600 dark:text-accent-yellow', tag: 'text-amber-600 dark:text-accent-yellow', border: 'border-accent-yellow/20' },
  purple: { bg: 'bg-brand-500/10',   icon: 'text-brand-400',   tag: 'text-brand-400',   border: 'border-brand-400/20' },
};
---

<PageLayout
  title="Servicios — BinaryDev"
  description="Sitios web profesionales, e-commerce, auditorías web y automatización de procesos. Soluciones digitales a medida para hacer crecer tu negocio."
>

  <!-- ── Intro ─────────────────────────────────────────────────── -->
  <section class="services-intro relative overflow-hidden bg-gray-950 py-28 lg:py-36">

    <!-- Glow de fondo -->
    <div class="pointer-events-none absolute inset-0" aria-hidden="true">
      <div class="absolute -top-40 right-0 h-[500px] w-[500px] rounded-full bg-brand-500/15 blur-[120px]"></div>
      <div class="absolute bottom-0 left-1/4 h-[300px] w-[300px] rounded-full bg-brand-700/10 blur-[100px]"></div>
    </div>

    <!-- Grid sutil -->
    <div class="services-grid pointer-events-none absolute inset-0" aria-hidden="true"></div>

    <div class="relative z-10 mx-auto max-w-6xl px-6">

      <!-- Label -->
      <p class="mb-6 text-sm font-bold uppercase tracking-[0.2em] text-brand-400">Servicios</p>

      <!-- H1 + descripción: layout tipo revista -->
      <div class="grid grid-cols-1 gap-10 lg:grid-cols-2 lg:gap-20">

        <div>
          <h1 class="font-display text-4xl font-black leading-[1.05] tracking-tight text-white text-balance sm:text-5xl lg:text-6xl">
            Soluciones digitales que hacen
            <span class="relative inline-block">
              <span class="relative z-10 text-brand-400">crecer tu negocio.</span>
            </span>
          </h1>
        </div>

        <div class="flex flex-col justify-center gap-5 text-lg leading-relaxed text-gray-400 lg:pt-2">
          <p>
            Cada negocio tiene una fricción distinta. Puede ser que perdés ventas porque no tenés presencia online, o que la tenés pero no convierte. Puede ser que tu equipo desperdicia horas en tareas que se podrían automatizar.
          </p>
          <p>
            Trabajo con foco en resultados concretos: webs que generan consultas, tiendas que venden, procesos que se agilizan. Sin vueltas, sin templates genéricos, sin soluciones de una sola talla.
          </p>
          <div class="mt-2">
            <Button href="/contacto" size="lg" class="bg-brand-500 text-white hover:bg-brand-400 shadow-lg shadow-brand-500/20 transition-all duration-300">
              Hablemos de tu caso
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
            </Button>
          </div>
        </div>

      </div>

      <!-- Separador con stats -->
      <div class="mt-16 grid grid-cols-2 gap-6 border-t border-white/10 pt-10 sm:grid-cols-4">
        {[
          { n: '20+', label: 'Proyectos entregados' },
          { n: '3–4', label: 'Semanas promedio' },
          { n: '100%', label: 'A medida' },
          { n: '5★', label: 'Valoración de clientes' },
        ].map(s => (
          <div>
            <p class="text-3xl font-black text-white">{s.n}</p>
            <p class="mt-1 text-sm text-gray-500">{s.label}</p>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- ── Cards de servicios ─────────────────────────────────────── -->
  <section class="py-20 lg:py-28">
    <div class="mx-auto max-w-6xl px-6">

      <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
        {services.map((s) => {
          const c = colorMap[s.color];
          return (
            <article class:list={["service-card group relative flex flex-col rounded-2xl border border-border bg-card p-8 transition-all duration-300 hover:border-border-strong hover:shadow-lg", "overflow-hidden"]}>

              <!-- Glow on hover -->
              <div class:list={["pointer-events-none absolute -top-16 -right-16 h-48 w-48 rounded-full opacity-0 blur-3xl transition-opacity duration-500 group-hover:opacity-100", c.bg]} aria-hidden="true"></div>

              <!-- Icon -->
              <div class:list={["mb-6 flex h-14 w-14 items-center justify-center rounded-xl", c.bg]}>
                <span class={c.icon} set:html={s.icon} />
              </div>

              <!-- Tag -->
              <p class:list={["mb-2 text-xs font-bold uppercase tracking-widest", c.tag]}>{s.tag}</p>

              <!-- Title -->
              <h2 class="font-display mb-4 text-2xl font-bold text-foreground">{s.title}</h2>

              <!-- Description -->
              <p class="mb-6 flex-1 text-base leading-relaxed text-foreground-muted">{s.description}</p>

              <!-- Feature list -->
              <ul class:list={["mb-8 space-y-2 border-t border-border pt-6"]}>
                {s.items.map(item => (
                  <li class="flex items-center gap-2.5 text-sm text-foreground-muted">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class:list={["shrink-0", c.icon]} aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                    {item}
                  </li>
                ))}
              </ul>

              <!-- CTA -->
              <Button
                href={s.href}
                variant="outline"
                size="sm"
                class="self-start"
              >
                Consultá por este servicio
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
              </Button>

            </article>
          );
        })}
      </div>

    </div>
  </section>

  <!-- ── ¿No sabés cuál necesitás? ─────────────────────────────── -->
  <section class="bg-secondary/50 py-16 lg:py-20">
    <div class="mx-auto max-w-3xl px-6 text-center">
      <p class="mb-3 text-sm font-bold uppercase tracking-widest text-brand-500">¿No sabés por dónde empezar?</p>
      <h2 class="font-display mb-4 text-3xl font-bold text-foreground text-balance md:text-4xl">
        Respondé 3 preguntas y te digo qué necesitás
      </h2>
      <p class="mb-8 text-lg text-foreground-muted">
        Un diagnóstico rápido y sin compromiso para entender cuál es la solución que más le conviene a tu negocio hoy.
      </p>
      <Button href="/#quiz" size="lg" class="bg-brand-500 text-white hover:bg-brand-400 shadow-lg shadow-brand-500/20 transition-all duration-300">
        Hacer el diagnóstico gratis
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
      </Button>
    </div>
  </section>

  <CTA />

</PageLayout>

<style>
  .services-grid {
    background-image:
      linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 30%, transparent 100%);
  }

  .service-card {
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    transform-style: preserve-3d;
    will-change: transform;
  }
</style>

<script>
  if (window.matchMedia('(hover: hover) and (pointer: fine)').matches) {
    document.querySelectorAll<HTMLElement>('.service-card').forEach((card) => {
      const STRENGTH = 6;
      card.addEventListener('mousemove', (e) => {
        const rect = card.getBoundingClientRect();
        const x = (e.clientX - rect.left) / rect.width - 0.5;
        const y = (e.clientY - rect.top) / rect.height - 0.5;
        card.style.transition = 'transform 0.08s ease-out';
        card.style.transform = `perspective(800px) rotateY(${x * STRENGTH}deg) rotateX(${-y * STRENGTH}deg) scale3d(1.02,1.02,1.02)`;
      });
      card.addEventListener('mouseleave', () => {
        card.style.transition = 'transform 0.4s ease-out';
        card.style.transform = 'perspective(800px) rotateY(0deg) rotateX(0deg) scale3d(1,1,1)';
      });
    });
  }
</script>
