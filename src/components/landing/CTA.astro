---
import Button from '@/components/ui/form/Button/Button.astro';
---

<section id="cta" class="relative overflow-hidden py-28 md:py-36">

  <!-- Imagen de fondo -->
  <div class="absolute inset-0">
    <img
      src="/images/ctabg-woman-typing.webp"
      alt=""
      aria-hidden="true"
      class="h-full w-full object-cover object-center"
    />
    <!-- Gradient oscuro sobre la imagen -->
    <div class="absolute inset-0 bg-gradient-to-r from-black/80 via-black/60 to-black/30"></div>
    <!-- Tinte de marca sutil desde abajo -->
    <div class="absolute inset-0 bg-gradient-to-t from-brand-500/20 via-transparent to-transparent"></div>
  </div>

  <!-- Partículas decorativas -->
  <div class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
    <div class="particle particle-1"></div>
    <div class="particle particle-2"></div>
    <div class="particle particle-3"></div>
  </div>

  <!-- Contenido -->
  <div class="relative mx-auto max-w-4xl px-6 text-center">

    <!-- Badge animado -->
    <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-white/20 bg-white/10 px-4 py-1.5 backdrop-blur-sm">
      <span class="h-2 w-2 animate-pulse rounded-full bg-brand-500"></span>
      <span class="text-xs font-semibold uppercase tracking-widest text-white/80">Trabajemos juntos</span>
    </div>

    <h2 class="font-display mb-5 text-4xl font-black leading-tight text-white text-balance md:text-5xl lg:text-6xl">
      Conversemos sobre
      <span class="relative inline-block">
        <span class="relative z-10 text-brand-500">tu proyecto</span>
        <span class="cta-underline absolute bottom-0 left-0 h-[3px] w-full rounded-full bg-brand-500/50"></span>
      </span>
    </h2>

    <p class="mx-auto mb-10 max-w-xl text-lg leading-relaxed text-white/70 md:text-xl">
      ¡Da el primer paso hacia un sitio web que genera resultados!
    </p>

    <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
      <Button
        href="/contacto"
        size="lg"
        class="cta-btn-primary group relative overflow-hidden bg-brand-500 text-white hover:bg-brand-600 shadow-lg shadow-brand-500/30"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
          fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
          stroke-linejoin="round" aria-hidden="true" class="shrink-0">
          <rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/>
          <line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/>
          <path d="m9 16 2 2 4-4"/>
        </svg>
        Agendá una reunión
      </Button>

      <Button
        href="https://wa.me/5492477235288"
        target="_blank"
        rel="noopener noreferrer"
        size="lg"
        variant="outline"
        class="border-white/30 bg-white/10 text-white backdrop-blur-sm hover:bg-white/20 hover:border-white/50"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
          fill="currentColor" aria-hidden="true" class="shrink-0">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Escribinos por WhatsApp
      </Button>
    </div>

  </div>
</section>

<style>
  /* Partículas flotantes */
  .particle {
    position: absolute;
    border-radius: 50%;
    background: var(--color-brand-500, #f94c10);
    opacity: 0.15;
    animation: float linear infinite;
  }
  .particle-1 {
    width: 300px; height: 300px;
    top: -80px; left: -60px;
    animation-duration: 18s;
    filter: blur(60px);
  }
  .particle-2 {
    width: 200px; height: 200px;
    bottom: -60px; right: 10%;
    animation-duration: 14s;
    animation-delay: -5s;
    filter: blur(50px);
  }
  .particle-3 {
    width: 150px; height: 150px;
    top: 30%; right: -40px;
    animation-duration: 20s;
    animation-delay: -10s;
    filter: blur(40px);
  }

  @keyframes float {
    0%, 100% { transform: translateY(0px) scale(1); }
    33%       { transform: translateY(-20px) scale(1.05); }
    66%       { transform: translateY(10px) scale(0.97); }
  }

  /* Subrayado animado en el título */
  .cta-underline {
    transform: scaleX(0);
    transform-origin: left;
    animation: underline-in 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.4s forwards;
  }

  @keyframes underline-in {
    to { transform: scaleX(1); }
  }
</style>
