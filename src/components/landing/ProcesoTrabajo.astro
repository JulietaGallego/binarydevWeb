---
import Button from '@/components/ui/form/Button/Button.astro';
import { FadeIn } from '@/components/ui/scroll-text';
import ProcessCard from './ProcessCard';

const steps = [
  {
    name: 'Diagnóstico',
    subtitle: 'Entender antes de construir.',
    desc: 'Antes de escribir una sola línea de código necesito entender tu negocio: qué ofrecés, a quién le hablás y qué querés lograr. Con esa base defino la estructura, el alcance y la solución exacta para tu caso. Sin suposiciones, sin plantillas genéricas.',
    icon: 'search',
    image: '/images/process/diagnostico.webp',
  },
  {
    name: 'Diseño y desarrollo',
    subtitle: 'Tu visión convertida en experiencia.',
    desc: 'Diseño y desarrollo tu web como un recorrido con propósito. Cada sección, cada llamada a la acción guía al visitante hacia un objetivo concreto: convertirse en un cliente calificado. Trabajamos con entregas intermedias para que el resultado final sea exactamente lo que imaginaste.',
    icon: 'code',
    image: '/images/process/desarrollo.webp',
  },
  {
    name: 'Lanzamiento y evolución',
    subtitle: 'Publicar es el comienzo.',
    desc: 'Tu negocio va a cambiar, y tu web tiene que poder acompañarlo. Una vez publicado el proyecto te capacito para gestionarlo de forma autónoma y quedo disponible para ajustes y mejoras a medida que tu negocio crece.',
    icon: 'zap',
    image: '/images/process/lanzamiento.webp',
  },
] as const;
---

<section class="relative z-10 border-y border-border bg-background-secondary py-[var(--space-section-lg)]">
  <div class="container">
    <header class="mb-16 flex flex-col items-start justify-between gap-6 md:flex-row md:items-end">
      <FadeIn client:visible>
        <h2 class="font-display text-3xl font-bold text-foreground md:text-4xl">
          Así trabajamos juntos.
          <br />
          <span class="text-brand-500">Sin fricciones.</span>
        </h2>
        <p class="mt-4 max-w-2xl text-lg text-foreground-muted">
          Un proceso claro pensado para que tu visión sea el punto de partida y el resultado final.
        </p>
      </FadeIn>

      <FadeIn client:visible delay={0.1}>
        <Button size="lg" href="/quiz">
          ¿Qué web necesitás?
        </Button>
      </FadeIn>
    </header>

    <ol class="grid grid-cols-1 gap-8 md:grid-cols-3 md:gap-10">
      {steps.map((item, i) => (
        <FadeIn client:visible delay={i * 0.12}>
          <li class="h-full">
            <ProcessCard
              client:visible
              name={item.name}
              subtitle={item.subtitle}
              desc={item.desc}
              icon={item.icon}
              index={i}
              image={item.image}
            />
          </li>
        </FadeIn>
      ))}
    </ol>
  </div>
</section>
