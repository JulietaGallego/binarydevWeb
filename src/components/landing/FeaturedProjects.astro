---
import { getCollection } from 'astro:content';
import ProjectCard from '@/components/patterns/ProjectCard.astro';
import Button from '@/components/ui/form/Button/Button.astro';

const featured = (await getCollection('projects', ({ data }) =>
  !data.draft && data.featured
)).sort((a, b) => a.data.order - b.data.order);
---

{featured.length > 0 && (
  <section id="featured-projects" class="relative z-10 bg-background pt-32 pb-20">
    <div class="container">

      <div id="fp-header" class="p-10 mb-10 flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 overflow-x-hidden">
        <div>
          <p class="text-xs font-bold uppercase tracking-widest text-brand-500 mb-3">Portfolio</p>
          <h2
            id="fp-title"
            class="font-black text-foreground leading-none"
            style="will-change: transform, font-size; transform: translateZ(0);"
          >
            <span class="fp-word block">Proyectos</span>
            <span class="fp-word block">destacados</span>
          </h2>
        </div>
        <div id="fp-cta" style="opacity: 0; transform: translateY(12px);">
          <Button href="/proyectos" variant="outline" size="sm">
            Ver todos
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
              fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"
              stroke-linejoin="round" aria-hidden="true" class="ml-1">
              <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
            </svg>
          </Button>
        </div>
      </div>

      <div id="fp-list" class="flex flex-col gap-6" style="opacity: 0; transform: translateY(40px);">
        {featured.map((project, i) => (
          <ProjectCard
            title={project.data.title}
            description={project.data.description}
            image={project.data.image}
            url={project.data.url}
            tags={project.data.tags}
            index={i}
          />
        ))}
      </div>

    </div>
  </section>
)}

<style>
  .fp-letter {
    display: inline-block;
    opacity: 0;
    filter: blur(8px);
    transform: translateY(4px);
    transition: opacity 0.4s ease, filter 0.4s ease, transform 0.4s ease;
  }

  .fp-letter.visible {
    opacity: 1;
    filter: blur(0);
    transform: translateY(0);
    text-shadow: 0 0 30px color-mix(in oklch, var(--color-brand-500) 40%, transparent);
  }

  .fp-letter.settled {
    text-shadow: none;
    transition: text-shadow 0.8s ease;
  }
</style>

<script>
  import { initFeaturedAnimation } from '@/scripts/featured-projects-animation';

  initFeaturedAnimation();
  document.addEventListener('astro:page-load', initFeaturedAnimation);
</script>
