---
import TextAnimation from '@/components/ui/scroll-text';
import { FadeIn } from '@/components/ui/scroll-text';
import MockupWebInstitucional from './MockupWebInstitucional';

const features = [
  { title: 'Diseño a medida', description: 'Estética alineada a tu identidad de marca para transmitir confianza desde el primer clic.' },
  { title: 'Centralización de consultas', description: 'Un solo lugar para recibir consultas, en vez de redes dispersas que se pierden.' },
  { title: 'Optimizado para celulares', description: 'El 80% de tus clientes te van a visitar desde el teléfono. Tu web tiene que estar lista.' },
];
---

<section id="web-institucional" class="relative z-10 bg-background py-[var(--space-section-lg)]">
  <div class="container">

    <div class="grid grid-cols-1 gap-12 lg:grid-cols-[58%_42%] lg:items-center lg:gap-24">

      <!-- Texto -->
      <div class="order-2 lg:order-1">
        <p class="mb-3 text-sm font-bold uppercase tracking-widest text-brand-500">
          Sitio web institucional
        </p>

        <TextAnimation
          client:visible
          text="Tu empresa necesita transmitir confianza las 24 horas"
          classname="font-display mb-5 text-3xl font-bold leading-tight text-foreground md:text-4xl"
          direction="up"
          duration={0.6}
          style="reveal"
        />

        <FadeIn client:visible delay={0.1} className="space-y-4 text-lg leading-relaxed text-foreground-muted">
          <p>
            Si tus clientes te buscan en Google y no te encontrás, o si tu web no refleja la calidad de tu trabajo, estás perdiendo oportunidades frente a la competencia.
          </p>
          <p>
            Desarrollamos sitios institucionales rápidos, modernos y pensados para convertir visitas en consultas reales.
          </p>
        </FadeIn>

        <div class="mt-10 grid grid-cols-1 gap-6 border-t border-border pt-10 sm:grid-cols-3">
          {features.map((f, i) => (
            <FadeIn client:visible delay={0.15 + i * 0.1}>
              <p class="mb-1 font-semibold text-foreground">{f.title}</p>
              <p class="text-sm leading-relaxed text-foreground-muted">{f.description}</p>
            </FadeIn>
          ))}
        </div>
      </div>

      <!-- Mockup web -->
      <div class="order-1 lg:order-2">
        <MockupWebInstitucional client:visible />
      </div>

    </div>
  </div>
</section>
