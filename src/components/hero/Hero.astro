---
import type { HTMLAttributes } from 'astro/types';
import { cn } from '@/lib/cn';
import { heroSectionVariants } from './hero.variants';

type Columns = '50/50' | '60/40' | '40/60' | '70/30' | '30/70' | '65/35' | '35/65';

interface Props extends HTMLAttributes<'section'> {
  /** Layout mode: centered single column or split two-column */
  layout?: 'centered' | 'split';
  /** Vertical padding size */
  size?: 'sm' | 'md' | 'lg' | 'xl';
  /** Show background grid pattern */
  showGrid?: boolean;
  /** Stick the hero to the top so the next section scrolls over it */
  sticky?: boolean;
  /**
   * Column split for split layout. First value = left column, second = right.
   * e.g. "60/40" → content 60% left, aside 40% right (default: "50/50")
   */
  columns?: Columns;
  /**
   * Invert column order from md breakpoint up.
   * DOM order is always preserved on mobile.
   */
  reverse?: boolean;
}

const {
  layout = 'centered',
  size = 'lg',
  showGrid = false,
  sticky = false,
  columns = '50/50',
  reverse = false,
  class: className,
  ...attrs
} = Astro.props;

const hasBadgeSlot       = Astro.slots.has('badge');
const hasTitleSlot       = Astro.slots.has('title');
const hasDescriptionSlot = Astro.slots.has('description');
const hasActionsSlot     = Astro.slots.has('actions');
const hasAsideSlot       = Astro.slots.has('aside');

const isSplit   = layout === 'split';
const alignment = layout === 'centered' ? 'text-center items-center' : 'text-left items-start';

// Static map so Tailwind's scanner picks up every class string
const colsMap: Record<Columns, string> = {
  '50/50': 'md:grid-cols-2',
  '60/40': 'md:grid-cols-[60%_40%]',
  '40/60': 'md:grid-cols-[40%_60%]',
  '70/30': 'md:grid-cols-[70%_30%]',
  '30/70': 'md:grid-cols-[30%_70%]',
  '65/35': 'md:grid-cols-[65%_35%]',
  '35/65': 'md:grid-cols-[35%_65%]',
};

const sectionClasses = cn(
  heroSectionVariants({ size }),
  sticky && 'sticky top-0 z-0',
  className
);

const gridClasses = cn(
  'container mx-auto grid grid-cols-1 items-center gap-[var(--space-section-gap)]',
  isSplit && colsMap[columns]
);
---

<section class={sectionClasses} {...attrs}>
  {showGrid && (
    <div
      class="bg-grid-pattern pointer-events-none absolute inset-0 [mask-image:linear-gradient(to_bottom,white,transparent)] opacity-40"
      aria-hidden="true"
    />
  )}

  <div class={gridClasses}>

    {/* Content Column */}
    <div class={cn(
      'z-10 flex flex-col',
      alignment,
      isSplit && reverse && 'md:order-2'
    )}>

      {hasBadgeSlot && (
        <div class="mb-[var(--space-heading-gap)]">
          <slot name="badge" />
        </div>
      )}

      {hasTitleSlot && (
        <div class={cn(
          'mb-[var(--space-heading-gap)]',
          '[&>h1]:font-display [&>h1]:text-5xl [&>h1]:leading-[1.1] [&>h1]:font-bold [&>h1]:tracking-tight [&>h1]:text-balance [&>h1]:text-foreground md:[&>h1]:text-6xl lg:[&>h1]:text-7xl',
          '[&>h2]:font-display [&>h2]:text-4xl [&>h2]:leading-[1.1] [&>h2]:font-bold [&>h2]:tracking-tight [&>h2]:text-balance [&>h2]:text-foreground md:[&>h2]:text-5xl lg:[&>h2]:text-6xl'
        )}>
          <slot name="title" />
        </div>
      )}

      {hasDescriptionSlot && (
        <div class={cn(
          'mb-[var(--space-stack-lg)] max-w-xl text-lg leading-relaxed text-foreground-muted',
          '[&>p]:text-lg [&>p]:leading-relaxed [&>p]:text-foreground-muted',
          layout === 'centered' && 'mx-auto'
        )}>
          <slot name="description" />
        </div>
      )}

      {hasActionsSlot && (
        <div class={cn(
          'flex w-full flex-col gap-4 sm:w-auto sm:flex-row',
          layout === 'centered' && 'justify-center'
        )}>
          <slot name="actions" />
        </div>
      )}

      <slot />
    </div>

    {/* Aside Column */}
    {isSplit && hasAsideSlot && (
      <div class={cn(
        'relative z-10 w-full',
        reverse && 'md:order-1'
      )}>
        <slot name="aside" />
      </div>
    )}

  </div>
</section>
