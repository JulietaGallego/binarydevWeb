---
import LandingLayout from '@/layouts/LandingLayout.astro';
import { Hero } from '@/components/hero';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import ProcesoTrabajo from '@/components/landing/ProcesoTrabajo.astro';
import WebInstitucional from '@/components/landing/WebInstitucional.astro';
import TiendaOnline from '@/components/landing/TiendaOnline.astro';
import Faq from '@/components/landing/Faq.astro';
import QuizSection from '@/components/landing/QuizSection.astro';
import CTA from '@/components/landing/CTA.astro';
import FeaturedProjects from '@/components/landing/FeaturedProjects.astro';
---

<LandingLayout
  title="BinaryDev — Diseño y desarrollo web"
  description="Diseño, desarrollo y estrategia digital para negocios que quieren crecer en internet. Webs que convierten visitas en clientes."
>
  <Hero layout="split" columns="1fr 2fr" reverse size="xl" showGrid sticky>

    <!-- Col 1 (30%): aside — ubicación + servicios -->
    <div slot="aside" class="flex flex-col justify-between h-full gap-10 py-4">
      <div>
        <p class="text-xs uppercase tracking-widest text-foreground-muted mb-1">Ubicación</p>
        <p class="text-sm font-medium text-foreground">Pergamino, Buenos Aires</p>
        <p class="text-sm text-foreground-muted">Argentina</p>
      </div>
      <div>
        <p class="text-xs uppercase tracking-widest text-foreground-muted mb-3">Servicios</p>
        <ul class="flex flex-col gap-1.5 text-sm text-foreground-muted">
          {['Diseño web', 'Desarrollo', 'E-commerce', 'UX / UI', 'SEO técnico', 'Automatizaciones'].map(s => (
            <li class="flex items-center gap-2">
              <span class="h-px w-4 bg-brand-500/60 shrink-0"></span>
              {s}
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Col 2 (70%): título + descripción + botones -->
    <Badge slot="badge" pill>Diseño web · Buenos Aires</Badge>

    <h1 slot="title">
      Webs que convierten<br />
      <span class="text-brand-500">visitas en clientes.</span>
    </h1>

    <p slot="description">
      Diseño y desarrollo sitios web a medida para negocios que quieren crecer en internet. Sin templates genéricos, sin soluciones de una sola talla.
    </p>

    <div slot="actions">
      <Button href="/quiz" size="lg">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
          fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
          stroke-linejoin="round" aria-hidden="true" class="shrink-0">
          <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
        </svg>
        ¿Qué web necesitás?
      </Button>
      <Button href="/proyectos" variant="outline" size="lg">
        Portfolio
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
          fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
          stroke-linejoin="round" aria-hidden="true" class="shrink-0">
          <path d="m9 18 6-6-6-6"/>
        </svg>
      </Button>
    </div>
  </Hero>

  <FeaturedProjects />
  <WebInstitucional />
  <TiendaOnline />
  <QuizSection />
  <ProcesoTrabajo />
  <Faq />
  <CTA />

</LandingLayout>
