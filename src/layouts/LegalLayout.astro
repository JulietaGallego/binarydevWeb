---
import PageLayout from './PageLayout.astro';

interface Props {
  title: string;
  description: string;
  lastUpdated?: string;
}

const { title, description, lastUpdated = '8 de junio de 2026' } = Astro.props;

const currentPath = Astro.url.pathname;

const links = [
  { href: '/legal/privacidad',  label: 'Política de Privacidad' },
  { href: '/legal/terminos',    label: 'Términos y Condiciones' },
  { href: '/legal/cookies',     label: 'Política de Cookies' },
];
---

<PageLayout title={`${title} — BinaryDev`} description={description}>
  <div class="mx-auto max-w-6xl px-6 py-16 pt-28">
    <div class="flex flex-col gap-10 lg:flex-row lg:gap-16">

      <!-- Sidebar -->
      <aside class="shrink-0 lg:w-56">
        <p class="mb-3 text-xs font-semibold uppercase tracking-widest text-foreground-subtle">Legales</p>
        <nav class="flex flex-row gap-2 lg:flex-col">
          {links.map(link => (
            <a
              href={link.href}
              class:list={[
                'rounded-lg px-3 py-2 text-sm font-medium transition-colors',
                currentPath === link.href
                  ? 'bg-brand-500/10 text-brand-500'
                  : 'text-foreground-muted hover:text-foreground hover:bg-secondary'
              ]}
            >
              {link.label}
            </a>
          ))}
        </nav>
      </aside>

      <!-- Contenido -->
      <main class="min-w-0 flex-1">
        <div class="mb-8 border-b border-border pb-6">
          <h1 class="font-display text-3xl font-bold text-foreground">{title}</h1>
          <p class="mt-2 text-sm text-foreground-muted">Última actualización: {lastUpdated}</p>
        </div>

        <div class="prose prose-lg prose-headings:font-display prose-headings:font-bold prose-a:text-brand-500 hover:prose-a:text-brand-600 dark:prose-invert max-w-none">
          <slot />
        </div>
      </main>

    </div>
  </div>
</PageLayout>
