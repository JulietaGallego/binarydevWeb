---
// src/components/landing/DiagnosticQuiz.astro
// Componente de quiz diagnóstico. Toda la data está en src/data/quiz.ts.
import { getStep, getResult, TOTAL_STEPS } from "../../lib/quiz";

// Pre-renderizamos el primer paso en el servidor para evitar flash en carga
const firstStep = getStep(1);
---

<div
  id="quiz-container"
  class="w-full max-w-3xl mx-auto bg-card rounded-2xl shadow-xl overflow-hidden border border-border flex flex-col"
  style="min-height: 560px;"
>
  <!-- Barra de progreso -->
  <div class="w-full bg-secondary h-1.5">
    <div
      id="progress-bar"
      class="bg-brand-500 h-full"
      style="width: 0%; transition: width 0.5s ease;"
    ></div>
  </div>

  <!-- Header -->
  <div class="px-6 pt-5 pb-4 flex items-center justify-between border-b border-border/50">
    <button
      id="prev-btn"
      type="button"
      class="group flex items-center gap-1.5 text-sm font-medium text-foreground-muted hover:text-foreground transition-colors"
      style="visibility: hidden;"
      aria-label="Volver al paso anterior"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="transition-transform group-hover:-translate-x-0.5"
        aria-hidden="true"
      >
        <path d="m15 18-6-6 6-6" />
      </svg>
      Volver
    </button>

    <span
      id="step-indicator"
      class="text-xs font-bold uppercase tracking-widest text-foreground-subtle ml-auto"
      aria-live="polite"
    >
      Paso 1 de {TOTAL_STEPS}
    </span>
  </div>

  <!-- Área de contenido -->
  <div class="flex-1 px-6 py-8 md:px-10 md:py-10">
    <div id="step-content">
      <!--
        SSR: primer paso pre-renderizado para evitar CLS.
        El script toma el control apenas hidrata.
      -->
      <div class="mb-7">
        <h2 class="text-xl font-bold text-foreground leading-snug">
          {firstStep.title}
        </h2>
        {firstStep.subtitle && (
          <p class="mt-1.5 text-sm text-foreground-muted">{firstStep.subtitle}</p>
        )}
      </div>

      <div class="flex flex-col gap-3">
        {firstStep.options.map((opt) => (
          <button
            type="button"
            data-option-id={opt.id}
            class="quiz-option group w-full text-left rounded-xl border border-border bg-card p-4 md:p-5 hover:border-brand-500 hover:shadow-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500 active:scale-[0.99] transition-all duration-200"
          >
            <div class="flex items-start gap-3">
              <span
                class="mt-0.5 flex-shrink-0 w-5 h-5 rounded-full border-2 border-border group-hover:border-brand-500 transition-colors"
                aria-hidden="true"
              ></span>
              <div>
                <p class="text-sm font-semibold text-foreground group-hover:text-brand-500 transition-colors leading-snug">
                  {opt.label}
                </p>
                {opt.detail && (
                  <p class="mt-1 text-xs text-foreground-muted leading-relaxed">
                    {opt.detail}
                  </p>
                )}
              </div>
            </div>
          </button>
        ))}
      </div>
    </div>
  </div>
</div>

<script>
  import { getStep, getResult, TOTAL_STEPS }  from "../../lib/quiz";
  
  import type { QuizStep }  from "../../lib/quiz";

  // ─── ESTADO ───────────────────────────────────────────────────────────────

  let currentStep = 1;
  const sel = { s1: "", s2: "", s3: "" };

  // ─── REFERENCIAS DOM ──────────────────────────────────────────────────────

  const contentEl  = document.getElementById("step-content")!;
  const prevBtn    = document.getElementById("prev-btn") as HTMLButtonElement;
  const progressEl = document.getElementById("progress-bar")!;
  const indicator  = document.getElementById("step-indicator")!;

  // ─── HEADER ───────────────────────────────────────────────────────────────

  function updateHeader() {
    const pct =
      currentStep <= TOTAL_STEPS
        ? (currentStep / (TOTAL_STEPS + 1)) * 100
        : 100;
    progressEl.style.width = `${pct}%`;

    indicator.textContent =
      currentStep <= TOTAL_STEPS
        ? `Paso ${currentStep} de ${TOTAL_STEPS}`
        : "Tu resultado";

    prevBtn.style.visibility = currentStep > 1 ? "visible" : "hidden";
  }

  // ─── TRANSICIÓN ───────────────────────────────────────────────────────────

  function transition(renderFn: () => void) {
    contentEl.style.transition = "opacity 0.2s ease, transform 0.2s ease";
    contentEl.style.opacity = "0";
    contentEl.style.transform = "translateX(10px)";

    setTimeout(() => {
      renderFn();
      contentEl.style.transform = "translateX(-10px)";
      contentEl.style.opacity = "0";

      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          contentEl.style.transition = "opacity 0.25s ease, transform 0.25s ease";
          contentEl.style.opacity = "1";
          contentEl.style.transform = "translateX(0)";
        });
      });
    }, 220);
  }

  // ─── RENDER OPCIONES ──────────────────────────────────────────────────────

  function renderOptions(step: QuizStep) {
    contentEl.innerHTML = `
      <div class="mb-7">
        <h2 class="text-xl font-bold text-foreground leading-snug">${step.title}</h2>
        ${step.subtitle
          ? `<p class="mt-1.5 text-sm text-foreground-muted">${step.subtitle}</p>`
          : ""}
      </div>
      <div class="flex flex-col gap-3" id="options-list"></div>
    `;

    const list = document.getElementById("options-list")!;

    step.options.forEach((opt) => {
      const btn = document.createElement("button");
      btn.type = "button";
      btn.setAttribute("data-option-id", opt.id);
      btn.className = [
        "quiz-option group w-full text-left",
        "rounded-xl border border-border bg-card",
        "p-4 md:p-5",
        "hover:border-brand-500 hover:shadow-md",
        "focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500",
        "active:scale-[0.99] transition-all duration-200",
      ].join(" ");

      btn.innerHTML = `
        <div class="flex items-start gap-3">
          <span
            class="mt-0.5 flex-shrink-0 w-5 h-5 rounded-full border-2 border-border
                   group-hover:border-brand-500 transition-colors"
            aria-hidden="true"
          ></span>
          <div>
            <p class="text-sm font-semibold text-foreground group-hover:text-brand-500
                      transition-colors leading-snug">
              ${opt.label}
            </p>
            ${opt.detail
              ? `<p class="mt-1 text-xs text-foreground-muted leading-relaxed">${opt.detail}</p>`
              : ""}
          </div>
        </div>
      `;

      btn.addEventListener("click", () => handleOptionClick(opt.id));
      list.appendChild(btn);
    });
  }

  // ─── ANALYTICS ────────────────────────────────────────────────────────────

  function trackEvent(name: string, params: Record<string, string>) {
    const w = window as typeof window & { gtag?: (...args: unknown[]) => void };
    if (typeof w.gtag === "function") {
      w.gtag("event", name, params);
    }
  }

  // ─── RENDER RESULTADO ─────────────────────────────────────────────────────

  const INPUT_CLASS = [
    "w-full rounded-lg border border-border bg-background",
    "px-3.5 py-2.5 text-sm text-foreground placeholder:text-foreground-subtle",
    "focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent",
    "transition-colors",
  ].join(" ");

  function renderResult() {
    const res = getResult(sel.s1, sel.s2, sel.s3);

    trackEvent("quiz_result_viewed", { service: res.service, result_title: res.title });

    contentEl.innerHTML = `
      <div class="space-y-6">

        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full
                    bg-brand-500/10 border border-brand-500/20">
          <span class="w-1.5 h-1.5 rounded-full bg-brand-500" aria-hidden="true"></span>
          <span class="text-xs font-bold text-brand-500 uppercase tracking-widest">
            ${res.service}
          </span>
        </div>

        <div>
          <h2 class="text-2xl font-black text-foreground leading-tight">${res.title}</h2>
          <p class="mt-3 text-foreground-muted leading-relaxed">${res.desc}</p>
        </div>

        <hr class="border-border/50" />

        <div class="space-y-4">
          <p class="text-sm font-semibold text-foreground">¿Querés que trabajemos en esto juntos?</p>
          <p class="text-xs text-foreground-muted -mt-2">Completá tus datos y elegí cómo contactarnos.</p>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            <input id="lead-name"     type="text"  placeholder="Tu nombre *"          class="${INPUT_CLASS}" />
            <input id="lead-business" type="text"  placeholder="Nombre del negocio *" class="${INPUT_CLASS}" />
            <input id="lead-email"    type="email" placeholder="Tu email *"            class="${INPUT_CLASS}" />
            <input id="lead-whatsapp" type="tel"   placeholder="Tu WhatsApp *"           class="${INPUT_CLASS}" />
          </div>

          <p id="lead-error" class="hidden text-xs text-red-500">
            Por favor completá todos los campos antes de continuar.
          </p>

          <div class="flex flex-col sm:flex-row gap-3">
            <button
              id="send-whatsapp"
              type="button"
              class="inline-flex items-center justify-center gap-2 px-5 py-2.5 rounded-xl
                     bg-[#25D366] text-white text-sm font-semibold
                     hover:bg-[#1fbe5a] transition-colors"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              Enviar por WhatsApp
            </button>
            <button
              id="send-email"
              type="button"
              class="inline-flex items-center justify-center gap-2 px-5 py-2.5 rounded-xl
                     border border-border bg-card text-sm font-medium text-foreground
                     hover:border-brand-500 hover:text-brand-500 transition-colors"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                stroke-linejoin="round" aria-hidden="true">
                <rect width="20" height="16" x="2" y="4" rx="2"/>
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
              </svg>
              Enviar por Email
            </button>
          </div>

          <button
            id="restart-btn"
            type="button"
            class="text-xs text-foreground-subtle hover:text-foreground-muted transition-colors underline underline-offset-2"
          >
            Volver a empezar
          </button>
        </div>

      </div>
    `;

    function getLeadData() {
      const name     = (document.getElementById("lead-name")     as HTMLInputElement).value.trim();
      const business = (document.getElementById("lead-business") as HTMLInputElement).value.trim();
      const email    = (document.getElementById("lead-email")    as HTMLInputElement).value.trim();
      const whatsapp = (document.getElementById("lead-whatsapp") as HTMLInputElement).value.trim();
      return { name, business, email, whatsapp };
    }

    function validateLead(data: { name: string; business: string; email: string; whatsapp: string }): boolean {
      return !!(data.name && data.business && data.email && data.whatsapp);
    }

    document.getElementById("send-whatsapp")?.addEventListener("click", () => {
      const data = getLeadData();
      const errorEl = document.getElementById("lead-error")!;
      if (!validateLead(data)) {
        errorEl.classList.remove("hidden");
        return;
      }
      errorEl.classList.add("hidden");
      trackEvent("quiz_lead_intent", { method: "whatsapp", service: res.service });

      const lines = [
        `Hola Julieta! Hice el quiz de BinaryDev y obtuve este resultado:`,
        ``,
        `*Servicio:* ${res.service}`,
        `*Diagnóstico:* ${res.title}`,
        ``,
        `Mis datos:`,
        `• Nombre: ${data.name}`,
        `• Negocio: ${data.business}`,
        `• Email: ${data.email}`,
        data.whatsapp ? `• WhatsApp: ${data.whatsapp}` : "",
      ].filter((l) => l !== undefined);

      const text = encodeURIComponent(lines.join("\n"));
      window.open(`https://wa.me/5492477235288?text=${text}`, "_blank");
    });

    document.getElementById("send-email")?.addEventListener("click", () => {
      const data = getLeadData();
      const errorEl = document.getElementById("lead-error")!;
      if (!validateLead(data)) {
        errorEl.classList.remove("hidden");
        return;
      }
      errorEl.classList.add("hidden");
      trackEvent("quiz_lead_intent", { method: "email", service: res.service });

      const subject = encodeURIComponent(`Diagnóstico BinaryDev: ${res.service}`);
      const body = encodeURIComponent(
        [
          `Hola Julieta,`,
          ``,
          `Completé el quiz de diagnóstico de BinaryDev y obtuve el siguiente resultado:`,
          ``,
          `Servicio: ${res.service}`,
          `Diagnóstico: ${res.title}`,
          ``,
          `Mis datos:`,
          `- Nombre: ${data.name}`,
          `- Negocio: ${data.business}`,
          `- Email: ${data.email}`,
          data.whatsapp ? `- WhatsApp: ${data.whatsapp}` : "",
          ``,
          `Quedo a disposición para coordinar una reunión.`,
        ].filter((l) => l !== undefined).join("\n")
      );

      window.location.href = `mailto:julieta@binarydev.com.ar?subject=${subject}&body=${body}`;
    });

    document.getElementById("restart-btn")?.addEventListener("click", restart);
  }

  // ─── LÓGICA DE NAVEGACIÓN ─────────────────────────────────────────────────

  function handleOptionClick(optionId: string) {
    trackEvent("quiz_step_selected", { step: String(currentStep), option_id: optionId });

    if (currentStep === 1) sel.s1 = optionId;
    else if (currentStep === 2) sel.s2 = optionId;
    else if (currentStep === 3) sel.s3 = optionId;

    currentStep++;
    updateHeader();

    transition(() => {
      if (currentStep > TOTAL_STEPS) {
        renderResult();
      } else {
        renderOptions(getStep(currentStep, sel.s1));
      }
    });
  }

  function goBack() {
    if (currentStep <= 1) return;
    currentStep--;
    if (currentStep === 3) sel.s3 = "";
    if (currentStep === 2) sel.s2 = "";
    updateHeader();
    transition(() => renderOptions(getStep(currentStep, sel.s1)));
  }

  function restart() {
    currentStep = 1;
    sel.s1 = sel.s2 = sel.s3 = "";
    updateHeader();
    transition(() => renderOptions(getStep(1)));
  }

  // ─── EVENTOS ──────────────────────────────────────────────────────────────

  prevBtn.addEventListener("click", goBack);

  // Delegación de eventos para el primer paso (pre-renderizado por SSR)
  contentEl.addEventListener("click", (e) => {
    const btn = (e.target as Element).closest<HTMLButtonElement>("[data-option-id]");
    if (btn && currentStep === 1) {
      handleOptionClick(btn.dataset.optionId!);
    }
  });

  // Sincronizar header con el SSR inicial
  updateHeader();
</script>
