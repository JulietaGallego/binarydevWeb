---
import TextAnimation from '@/components/ui/scroll-text';
import { FadeIn } from '@/components/ui/scroll-text';
import MockupTiendaOnline from './MockupTiendaOnline';

const features = [
  { title: 'Pagos integrados', description: 'Mercado Pago, tarjetas y transferencias. Tus clientes eligen cómo pagar.' },
  { title: 'Control de stock', description: 'Catálogo sincronizado en tiempo real para evitar ventas de productos sin existencia.' },
  { title: 'Pedidos automáticos', description: 'Recibís cada orden con los datos completos, sin tener que coordinar nada por WhatsApp.' },
];
---

<section id="tienda-online" class="relative z-10 bg-secondary py-[var(--space-section-lg)]">
  <div class="container">

    <div class="grid grid-cols-1 gap-12 lg:grid-cols-[42%_58%] lg:items-center lg:gap-24">

      <!-- Mockup tienda — primero en mobile, izquierda en desktop -->
      <div class="order-1">
        <MockupTiendaOnline client:visible />
      </div>

      <!-- Texto — segundo en mobile, derecha en desktop -->
      <div class="order-2">
        <p class="mb-3 text-sm font-bold uppercase tracking-widest text-brand-500">
          Tienda online
        </p>

        <TextAnimation
          client:visible
          text="Dejá de vender por WhatsApp. Tu tienda trabaja mientras dormís."
          classname="font-display mb-5 text-3xl font-bold leading-tight text-foreground md:text-4xl"
          direction="up"
          duration={0.6}
          style="reveal"
        />

        <FadeIn client:visible delay={0.1} className="space-y-4 text-lg leading-relaxed text-foreground-muted">
          <p>
            Dejá de pasar precios uno por uno y de coordinar pagos a mano.
          </p>
          <p>
            Tu negocio necesita un sistema que muestre tu stock real, reciba pedidos y procese cobros de forma automática, incluso los domingos y feriados.
          </p>
        </FadeIn>

        <div class="mt-10 grid grid-cols-1 gap-6 border-t border-border pt-10 sm:grid-cols-3">
          {features.map((f, i) => (
            <FadeIn client:visible delay={0.15 + i * 0.1}>
              <p class="mb-1 font-semibold text-foreground">{f.title}</p>
              <p class="text-sm leading-relaxed text-foreground-muted">{f.description}</p>
            </FadeIn>
          ))}
        </div>
      </div>

    </div>
  </div>
</section>
