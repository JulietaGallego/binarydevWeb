---
import PageLayout from '@/layouts/PageLayout.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import { Hero } from '@/components/hero';
import siteConfig from '@/config/site.config';

const whatsappUrl = `https://wa.me/${siteConfig.phone?.replace(/\D/g, '')}`;
---

<PageLayout
  title="Contacto — BinaryDev"
  description="Hablemos de tu proyecto. Escribime por email o WhatsApp y te respondo en menos de 24 horas."
>
  <Hero layout="centered" size="sm" showGrid>
    <Badge slot="badge" pill pulse>Contacto</Badge>

    <h1 slot="title">
      Hablemos de tu <span class="text-brand-500">proyecto.</span>
    </h1>

    <p slot="description">
      Contame qué necesitás y te respondo en menos de 24 horas.
    </p>
  </Hero>

  <section class="py-20">
    <div class="mx-auto max-w-3xl px-6">
      <div class="flex flex-col gap-6">

        <!-- Email -->
        <a href={`mailto:${siteConfig.email}`} class="block">
          <Card hover padding="md">
            <div class="flex items-center gap-5">
              <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
                <Icon name="mail" size="lg" />
              </div>
              <div>
                <p class="text-sm text-foreground-muted mb-0.5">Email</p>
                <p class="font-semibold text-foreground text-lg">{siteConfig.email}</p>
                <p class="text-sm text-foreground-muted mt-0.5">Respondo en menos de 24 horas</p>
              </div>
              <Icon name="arrow-right" size="sm" class="ml-auto text-foreground-subtle" />
            </div>
          </Card>
        </a>

        <!-- WhatsApp -->
        <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="block">
          <Card hover padding="md">
            <div class="flex items-center gap-5">
              <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-[#25D366]/20 to-[#25D366]/5 flex items-center justify-center shrink-0">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" class="text-[#25D366]" aria-hidden="true">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
              </div>
              <div>
                <p class="text-sm text-foreground-muted mb-0.5">WhatsApp</p>
                <p class="font-semibold text-foreground text-lg">{siteConfig.phone}</p>
                <p class="text-sm text-foreground-muted mt-0.5">Para consultas rápidas</p>
              </div>
              <Icon name="arrow-right" size="sm" class="ml-auto text-foreground-subtle" />
            </div>
          </Card>
        </a>

        <!-- Quiz card -->
        <Card padding="md" class="border-brand-500/30 bg-brand-500/5">
          <div class="flex flex-col sm:flex-row items-start sm:items-center gap-5">
            <div class="w-14 h-14 rounded-2xl bg-brand-500/15 flex items-center justify-center text-brand-500 shrink-0">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="10"/>
                <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/>
                <path d="M12 17h.01"/>
              </svg>
            </div>
            <div class="flex-1">
              <p class="font-semibold text-foreground">¿No sabés qué necesitás?</p>
              <p class="text-sm text-foreground-muted mt-0.5">Respondé 3 preguntas rápidas y te digo exactamente qué solución te conviene.</p>
            </div>
            <Button href="/quiz" variant="outline" size="sm" class="shrink-0">
              Hacer el quiz →
            </Button>
          </div>
        </Card>

      </div>
    </div>
  </section>
</PageLayout>
