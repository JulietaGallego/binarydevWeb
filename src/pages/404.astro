---
import LandingLayout from '@/layouts/LandingLayout.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
---

<LandingLayout
  title="Página no encontrada"
  description="La página que buscás fue movida, eliminada o nunca existió."
  noindex
>
  <section class="relative min-h-[calc(100vh-8rem)] flex items-center justify-center overflow-hidden pt-16">
    <!-- Background Effects -->
    <div class="absolute inset-0 bg-grid-pattern [mask-image:radial-gradient(ellipse_at_center,white_20%,transparent_70%)] pointer-events-none opacity-40"></div>
    <div class="absolute top-1/4 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-brand-500/15 rounded-full blur-[120px] pointer-events-none"></div>
    <div class="absolute bottom-1/4 right-1/4 w-[400px] h-[400px] bg-brand-600/10 rounded-full blur-[100px] pointer-events-none"></div>

    <div class="relative container px-6">
      <div class="max-w-2xl mx-auto text-center">
        <!-- Animated 404 -->
        <div class="relative mb-8">
          <div class="error-code font-display text-[10rem] md:text-[14rem] lg:text-[18rem] font-bold leading-none tracking-tighter select-none">
            <span class="inline-block error-digit" style="animation-delay: 0s;">4</span>
            <span class="inline-block error-digit text-transparent bg-clip-text bg-gradient-to-br from-brand-400 via-brand-500 to-brand-600" style="animation-delay: 0.1s;">0</span>
            <span class="inline-block error-digit" style="animation-delay: 0.2s;">4</span>
          </div>
          <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
            <div class="w-32 h-32 md:w-48 md:h-48 bg-brand-500/20 rounded-full blur-[60px] animate-pulse"></div>
          </div>
        </div>

        <!-- Copy -->
        <h1 class="font-display text-2xl md:text-3xl font-bold text-foreground mb-4">
          Esta página no existe
        </h1>

        <p class="text-lg text-foreground-muted max-w-md mx-auto mb-10">
          Pero mientras tanto, podés jugar.
        </p>

        <!-- Snake Game -->
        <div class="mb-10">
          <div class="relative rounded-2xl border border-border bg-card overflow-hidden shadow-lg w-full max-w-[400px] mx-auto">
            <!-- Score bar -->
            <div class="flex items-center justify-between px-4 py-2 border-b border-border bg-background-secondary">
              <span class="text-xs text-foreground-muted font-medium">VIBORITA 404</span>
              <div class="flex items-center gap-3">
                <span class="text-xs text-foreground-muted">puntos: <span id="score" class="text-foreground font-bold">0</span></span>
                <span class="text-xs text-foreground-muted">récord: <span id="highscore" class="text-foreground font-bold">0</span></span>
              </div>
            </div>
            <canvas id="snake-canvas" width="400" height="400" style="width:100%;height:auto;display:block;"></canvas>
            <!-- Overlay -->
            <div id="game-overlay" class="absolute inset-0 top-[37px] flex flex-col items-center justify-center bg-card/90 backdrop-blur-sm">
              <p id="overlay-title" class="text-lg font-bold text-foreground mb-1">¿Jugamos?</p>
              <p id="overlay-sub" class="text-sm text-foreground-muted mb-4">Usá las flechas o WASD</p>
              <button id="start-btn" class="px-5 py-2 rounded-lg bg-brand-500 text-white text-sm font-semibold hover:bg-brand-600 transition-colors">
                Empezar
              </button>
            </div>
          </div>
          <!-- Mobile controls -->
          <div class="mt-4 grid grid-cols-3 gap-1 w-32 mx-auto md:hidden">
            <div></div>
            <button data-dir="UP"    class="touch-btn p-2 rounded-lg border border-border bg-card flex items-center justify-center">▲</button>
            <div></div>
            <button data-dir="LEFT"  class="touch-btn p-2 rounded-lg border border-border bg-card flex items-center justify-center">◀</button>
            <button data-dir="DOWN"  class="touch-btn p-2 rounded-lg border border-border bg-card flex items-center justify-center">▼</button>
            <button data-dir="RIGHT" class="touch-btn p-2 rounded-lg border border-border bg-card flex items-center justify-center">▶</button>
          </div>
        </div>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-12">
          <Button href="/" size="lg">
            <Icon name="arrow-left" size="sm" />
            Volver al inicio
          </Button>
          <Button href="/blog" variant="outline" size="lg">
            Ver el blog
          </Button>
        </div>

        <!-- Quick Links -->
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-secondary/50 border border-border">
          <span class="text-sm text-foreground-muted">Links rápidos:</span>
          <a href="/servicios" class="text-sm font-medium text-foreground hover:text-brand-500 transition-colors">
            Servicios
          </a>
          <span class="text-foreground-subtle">|</span>
          <a href="/contacto" class="text-sm font-medium text-foreground hover:text-brand-500 transition-colors">
            Contacto
          </a>
        </div>
      </div>
    </div>
  </section>
</LandingLayout>

<style>
  .error-code {
    color: var(--foreground);
    opacity: 0.15;
  }

  .error-digit {
    animation: float 3s ease-in-out infinite;
  }

  .error-digit:nth-child(2) {
    opacity: 1;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(-10px); }
  }

  :global(.dark) .error-code        { opacity: 0.1; }
  :global(.dark) .error-digit:nth-child(2) { opacity: 1; }

  .touch-btn { touch-action: manipulation; user-select: none; font-size: 0.75rem; color: var(--foreground-muted); }
</style>

<script>
  // Canvas 400×400, celda 16px → grilla 25×25 (serpiente más chica)
  const COLS = 25, ROWS = 25, CELL = 16;
  const SPEED = 180; // ms por tick

  const canvas     = document.getElementById('snake-canvas') as HTMLCanvasElement;
  const ctx        = canvas.getContext('2d')!;
  const scoreEl    = document.getElementById('score')!;
  const highEl     = document.getElementById('highscore')!;
  const overlay    = document.getElementById('game-overlay')!;
  const overlayT   = document.getElementById('overlay-title')!;
  const overlaySub = document.getElementById('overlay-sub')!;
  const startBtn   = document.getElementById('start-btn')!;

  type Dir = 'UP'|'DOWN'|'LEFT'|'RIGHT';
  type Pt  = { x: number; y: number };

  let snake: Pt[], dir: Dir, nextDir: Dir, food: Pt;
  let score = 0, highScore = 0, running = false, waiting = false, raf = 0, lastTime = 0;

  const OPPOSITE: Record<Dir, Dir> = { UP:'DOWN', DOWN:'UP', LEFT:'RIGHT', RIGHT:'LEFT' };
  const KEY_MAP: Record<string, Dir> = {
    ArrowUp:'UP', ArrowDown:'DOWN', ArrowLeft:'LEFT', ArrowRight:'RIGHT',
    w:'UP', s:'DOWN', a:'LEFT', d:'RIGHT',
    W:'UP', S:'DOWN', A:'LEFT', D:'RIGHT',
  };

  function rand(n: number) { return Math.floor(Math.random() * n); }

  function spawnFood() {
    let f: Pt;
    // garantiza que quede dentro del canvas y fuera de la serpiente
    do { f = { x: rand(COLS), y: rand(ROWS) }; }
    while (snake.some(s => s.x === f.x && s.y === f.y));
    food = f;
  }

  function init() {
    const mid = Math.floor(COLS / 2);
    snake   = [{ x: mid, y: mid }, { x: mid - 1, y: mid }, { x: mid - 2, y: mid }];
    dir     = 'RIGHT';
    nextDir = 'RIGHT';
    score   = 0;
    scoreEl.textContent = '0';
    spawnFood();
  }

  // Dibuja una manzana roja
  function drawApple(t: number) {
    const pulse = 0.85 + 0.15 * Math.sin(t / 400);
    const cx = food.x * CELL + CELL / 2;
    const cy = food.y * CELL + CELL / 2 + 1;
    const r  = (CELL / 2 - 2) * pulse;

    // glow suave
    const grd = ctx.createRadialGradient(cx, cy, 0, cx, cy, r * 2);
    grd.addColorStop(0, 'rgba(220,50,50,0.3)');
    grd.addColorStop(1, 'transparent');
    ctx.fillStyle = grd;
    ctx.fillRect(food.x * CELL - 4, food.y * CELL - 4, CELL + 8, CELL + 8);

    // cuerpo de la manzana
    ctx.fillStyle = '#e03535';
    ctx.beginPath();
    ctx.arc(cx, cy, r, 0, Math.PI * 2);
    ctx.fill();

    // brillo
    ctx.fillStyle = 'rgba(255,255,255,0.35)';
    ctx.beginPath();
    ctx.ellipse(cx - r * 0.25, cy - r * 0.3, r * 0.3, r * 0.2, -0.5, 0, Math.PI * 2);
    ctx.fill();

    // tallito
    ctx.strokeStyle = '#5a3010';
    ctx.lineWidth = 1.5;
    ctx.beginPath();
    ctx.moveTo(cx, food.y * CELL + 1);
    ctx.lineTo(cx + 2, food.y * CELL - 2);
    ctx.stroke();

    // hojita
    ctx.fillStyle = '#3a9e3a';
    ctx.beginPath();
    ctx.ellipse(cx + 4, food.y * CELL - 1, 3, 1.5, 0.5, 0, Math.PI * 2);
    ctx.fill();
  }

  function drawGrid() {
    ctx.strokeStyle = 'rgba(255,255,255,0.035)';
    ctx.lineWidth = 0.5;
    for (let x = 0; x <= COLS; x++) {
      ctx.beginPath(); ctx.moveTo(x * CELL, 0); ctx.lineTo(x * CELL, ROWS * CELL); ctx.stroke();
    }
    for (let y = 0; y <= ROWS; y++) {
      ctx.beginPath(); ctx.moveTo(0, y * CELL); ctx.lineTo(COLS * CELL, y * CELL); ctx.stroke();
    }
  }

  function drawSnake() {
    snake.forEach((seg, i) => {
      const isHead = i === 0;
      // degradado verde: cabeza más brillante, cola más oscura
      const lightness = isHead ? 0.55 : Math.max(0.28, 0.48 - i * 0.01);
      ctx.fillStyle = `hsl(${isHead ? 130 : 120}, 55%, ${lightness * 100}%)`;
      ctx.globalAlpha = isHead ? 1 : Math.max(0.5, 1 - i * 0.03);
      const pad = isHead ? 1 : 2;
      ctx.beginPath();
      ctx.roundRect(seg.x * CELL + pad, seg.y * CELL + pad, CELL - pad * 2, CELL - pad * 2, isHead ? 5 : 3);
      ctx.fill();

      // ojos en la cabeza
      if (isHead) {
        ctx.globalAlpha = 1;
        ctx.fillStyle = '#fff';
        const [ex1, ey1, ex2, ey2] = dir === 'RIGHT' ? [seg.x*CELL+10, seg.y*CELL+4,  seg.x*CELL+10, seg.y*CELL+10]
                                   : dir === 'LEFT'  ? [seg.x*CELL+3,  seg.y*CELL+4,  seg.x*CELL+3,  seg.y*CELL+10]
                                   : dir === 'UP'    ? [seg.x*CELL+4,  seg.y*CELL+3,  seg.x*CELL+10, seg.y*CELL+3]
                                                     : [seg.x*CELL+4,  seg.y*CELL+10, seg.x*CELL+10, seg.y*CELL+10];
        ctx.beginPath(); ctx.arc(ex1, ey1, 1.5, 0, Math.PI*2); ctx.fill();
        ctx.beginPath(); ctx.arc(ex2, ey2, 1.5, 0, Math.PI*2); ctx.fill();
        ctx.fillStyle = '#111';
        ctx.beginPath(); ctx.arc(ex1+0.5, ey1+0.5, 0.7, 0, Math.PI*2); ctx.fill();
        ctx.beginPath(); ctx.arc(ex2+0.5, ey2+0.5, 0.7, 0, Math.PI*2); ctx.fill();
      }
    });
    ctx.globalAlpha = 1;
  }

  function draw(t: number) {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    drawGrid();
    drawApple(t);
    drawSnake();
  }

  function tick() {
    dir = nextDir;
    const head = snake[0];
    const nx = head.x + (dir === 'RIGHT' ? 1 : dir === 'LEFT' ? -1 : 0);
    const ny = head.y + (dir === 'DOWN'  ? 1 : dir === 'UP'   ? -1 : 0);

    // muerte por bordes
    if (nx < 0 || nx >= COLS || ny < 0 || ny >= ROWS) { gameOver(); return; }

    // muerte por colisión consigo misma
    if (snake.some(s => s.x === nx && s.y === ny)) { gameOver(); return; }

    snake.unshift({ x: nx, y: ny });

    if (nx === food.x && ny === food.y) {
      score++;
      scoreEl.textContent = String(score);
      if (score > highScore) { highScore = score; highEl.textContent = String(highScore); }
      spawnFood(); // sin pop → se hace más larga
    } else {
      snake.pop();
    }
  }

  function loop(t: number) {
    if (!running) return;
    raf = requestAnimationFrame(loop);
    draw(t);
    if (t - lastTime >= SPEED) { tick(); lastTime = t; }
  }

  function showOverlay(title: string, sub: string, btn: string) {
    overlayT.textContent   = title;
    overlaySub.textContent = sub;
    startBtn.textContent   = btn;
    overlay.style.display  = 'flex';
  }

  function start() {
    init();
    overlay.style.display = 'none';
    // espera la primera tecla para empezar a moverse
    waiting = true;
    running = true;
    lastTime = 0;
    draw(0);
    raf = requestAnimationFrame(loop);
  }

  function gameOver() {
    running = false;
    waiting = false;
    cancelAnimationFrame(raf);
    showOverlay(
      score > 0 ? `¡${score} punto${score !== 1 ? 's' : ''}!` : 'Game over',
      score > 0 ? 'No está mal para estar perdida 😄' : 'Intentalo de nuevo',
      'Jugar de nuevo'
    );
  }

  // Controles teclado
  document.addEventListener('keydown', (e) => {
    const d = KEY_MAP[e.key];
    if (!d) return;
    if (['ArrowUp','ArrowDown','ArrowLeft','ArrowRight'].includes(e.key)) e.preventDefault();
    if (waiting) {
      // primera tecla arranca el movimiento
      if (d !== OPPOSITE[dir]) { nextDir = d; dir = d; }
      waiting = false;
      lastTime = performance.now();
      return;
    }
    if (d !== OPPOSITE[dir]) nextDir = d;
  });

  // Controles táctiles
  document.querySelectorAll<HTMLButtonElement>('.touch-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const d = btn.dataset.dir as Dir;
      if (!d) return;
      if (waiting) { if (d !== OPPOSITE[dir]) { nextDir = d; dir = d; } waiting = false; lastTime = performance.now(); return; }
      if (d !== OPPOSITE[dir]) nextDir = d;
    });
  });

  startBtn.addEventListener('click', start);

  // Dibujo inicial
  init();
  draw(0);
</script>
