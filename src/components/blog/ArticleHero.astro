---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { formatDate } from '@/lib/utils';

interface Props {
  title: string;
  description: string;
  publishedAt: Date;
  updatedAt?: Date;
  author?: string;
  tags?: string[];
  image?: ImageMetadata;
  imageAlt?: string;
}

const {
  title,
  description,
  publishedAt,
  author = 'Julieta Gallego',
  tags = [],
  image,
  imageAlt,
} = Astro.props;

const wordsPerMinute = 200;
const estimatedWords = description.split(' ').length * 15;
const readingTime = Math.max(1, Math.ceil(estimatedWords / wordsPerMinute));
---

<header class="article-hero relative overflow-hidden pt-16">

  {image ? (
    <>
      <!-- Imagen de fondo full-width -->
      <div class="absolute inset-0">
        <Image
          src={image}
          alt={imageAlt || title}
          widths={[800, 1200, 1920]}
          sizes="100vw"
          class="h-full w-full object-cover object-center"
          loading="eager"
        />
        <!-- Overlay oscuro degradado -->
        <div class="absolute inset-0 bg-gradient-to-t from-gray-950 via-gray-950/75 to-gray-950/50"></div>
        <!-- Tinte de marca sutil desde abajo -->
        <div class="absolute inset-0 bg-gradient-to-t from-brand-900/30 via-transparent to-transparent"></div>
      </div>

      <!-- Contenido sobre la imagen -->
      <div class="relative z-10 mx-auto max-w-4xl px-6 pb-16 pt-24 lg:pb-24 lg:pt-32">

        <!-- Tags -->
        {tags.length > 0 && (
          <div class="mb-6 flex flex-wrap gap-2">
            {tags.map((tag) => (
              <span class="rounded-full border border-white/20 bg-white/10 px-3 py-1 text-xs font-semibold text-white/90 backdrop-blur-sm">
                {tag}
              </span>
            ))}
          </div>
        )}

        <!-- Título -->
        <h1 class="font-display mb-5 text-4xl font-black leading-tight tracking-tight text-white text-balance md:text-5xl lg:text-6xl">
          {title}
        </h1>

        <!-- Descripción -->
        <p class="mb-8 max-w-2xl text-lg leading-relaxed text-white/70">
          {description}
        </p>

        <!-- Meta -->
        <div class="flex flex-wrap items-center gap-4 text-sm text-white/60">
          <div class="flex items-center gap-2">
            <div class="flex h-8 w-8 items-center justify-center rounded-full bg-brand-500 text-xs font-bold text-white">
              {author.charAt(0).toUpperCase()}
            </div>
            <span class="font-medium text-white/80">{author}</span>
          </div>
          <span aria-hidden="true">·</span>
          <time datetime={publishedAt.toISOString()}>{formatDate(publishedAt)}</time>
          <span aria-hidden="true">·</span>
          <span>{readingTime} min de lectura</span>
        </div>

      </div>
    </>
  ) : (
    <!-- Sin imagen: hero simple con fondo secundario -->
    <div class="border-b border-border bg-background-secondary">
      <div class="mx-auto max-w-4xl px-6 pb-12 pt-24">

        {tags.length > 0 && (
          <div class="mb-6 flex flex-wrap gap-2">
            {tags.map((tag) => (
              <span class="rounded-full bg-brand-500/10 px-3 py-1 text-xs font-semibold text-brand-500 ring-1 ring-inset ring-brand-500/20">
                {tag}
              </span>
            ))}
          </div>
        )}

        <h1 class="font-display mb-5 text-4xl font-black leading-tight tracking-tight text-foreground text-balance md:text-5xl">
          {title}
        </h1>

        <p class="mb-8 max-w-2xl text-lg leading-relaxed text-foreground-muted">
          {description}
        </p>

        <div class="flex flex-wrap items-center gap-4 text-sm text-foreground-subtle">
          <div class="flex items-center gap-2">
            <div class="flex h-8 w-8 items-center justify-center rounded-full bg-brand-500 text-xs font-bold text-white">
              {author.charAt(0).toUpperCase()}
            </div>
            <span class="font-medium text-foreground">{author}</span>
          </div>
          <span aria-hidden="true">·</span>
          <time datetime={publishedAt.toISOString()}>{formatDate(publishedAt)}</time>
          <span aria-hidden="true">·</span>
          <span>{readingTime} min de lectura</span>
        </div>

      </div>
    </div>
  )}

</header>
