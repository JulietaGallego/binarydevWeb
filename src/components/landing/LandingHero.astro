---
import { Hero } from '@/components/hero';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Button from '@/components/ui/form/Button/Button.astro';
---

<div class="relative">
  <Hero layout="centered" size="xl" showGrid class="min-h-screen">
    <Badge slot="badge" pill>Diseño web · Buenos Aires</Badge>

    <h1 slot="title">
      Webs que convierten<br />
      <span class="text-brand-500">visitas en clientes.</span>
    </h1>

    <p slot="description">
      Diseño y desarrollo sitios web a medida para negocios que quieren crecer en internet. Sin templates genéricos, sin soluciones de una sola talla.
    </p>

    <div slot="actions" class="flex flex-col items-center gap-4 sm:flex-row sm:justify-center w-full">
      <Button href="/quiz" size="lg">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
          fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
          stroke-linejoin="round" aria-hidden="true" class="shrink-0">
          <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
        </svg>
        ¿Qué web necesitás?
      </Button>
      <Button href="/proyectos" variant="outline" size="lg">
        Portfolio
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
          fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
          stroke-linejoin="round" aria-hidden="true" class="shrink-0">
          <path d="m9 18 6-6-6-6"/>
        </svg>
      </Button>
    </div>

    <!-- Service promises -->
    <div class="mt-10 flex flex-col items-center gap-3 sm:flex-row sm:justify-center sm:gap-6">
      {[
        'Mobile-first y accesible',
        'SEO técnico incluido',
        'Carga ultrarrápida',
      ].map((item) => (
        <span class="flex items-center gap-2 text-sm text-foreground-muted">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
            fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"
            stroke-linejoin="round" class="shrink-0 text-brand-500" aria-hidden="true">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
          {item}
        </span>
      ))}
    </div>
  </Hero>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-foreground-muted" aria-hidden="true">
    <span class="text-xs uppercase tracking-widest opacity-60">scroll</span>
    <div class="scroll-line relative h-10 w-px overflow-hidden rounded-full bg-border">
      <div class="scroll-dot absolute top-0 left-0 h-3 w-full rounded-full bg-brand-500"></div>
    </div>
  </div>
</div>

<style>
  .scroll-dot {
    animation: scroll-down 1.8s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }

  @keyframes scroll-down {
    0%   { transform: translateY(-100%); opacity: 0; }
    20%  { opacity: 1; }
    80%  { opacity: 1; }
    100% { transform: translateY(400%); opacity: 0; }
  }
</style>
