---
import Button from '@/components/ui/form/Button/Button.astro';
import { FadeIn } from '@/components/ui/scroll-text';
import ProcessCard from './ProcessCard';

const steps = [
  {
    name: 'Diagnóstico inicial',
    desc: 'Entiendo la prioridad de tu negocio y definimos la solución ideal para vos.',
    icon: 'search',
    image: '/images/process/diagnostico.webp',
  },
  {
    name: 'Diseño y desarrollo',
    desc: 'Construyo tu plataforma enfocándome en la velocidad, la estética y la facilidad de uso.',
    icon: 'code',
    image: '/images/process/desarrollo.webp',
  },
  {
    name: 'Lanzamiento y soporte',
    desc: 'Tu web queda online y lista para recibir clientes, con acompañamiento para que aprendas a usarla.',
    icon: 'zap',
    image: '/images/process/lanzamiento.webp',
  },
] as const;
---

<section class="relative z-10 border-y border-border bg-background-secondary py-[var(--space-section-sm)]">
  <div class="container">
    <header class="mb-12 flex flex-col items-start justify-between gap-6 md:flex-row md:items-end">
      <FadeIn client:visible>
        <h2 class="font-display text-3xl font-bold text-foreground md:text-4xl">
          Todo lo que necesitás.
          <br />
          <span class="text-brand-500">Sin costos de más.</span>
        </h2>
        <p class="mt-4 max-w-2xl text-lg text-foreground-muted">
          Un proceso claro, sin tecnicismos ni vueltas.
        </p>
      </FadeIn>

      <FadeIn client:visible delay={0.1}>
        <Button size="lg" href="/quiz">
          ¿Qué web necesitás?
        </Button>
      </FadeIn>
    </header>

    <ol class="grid grid-cols-1 gap-[var(--space-content-gap)] md:grid-cols-3">
      {steps.map((item, i) => (
        <FadeIn client:visible delay={i * 0.12}>
          <li class="h-full">
            <ProcessCard
              client:visible
              name={item.name}
              desc={item.desc}
              icon={item.icon}
              index={i}
              image={item.image}
            />
          </li>
        </FadeIn>
      ))}
    </ol>
  </div>
</section>
